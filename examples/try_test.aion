# Test try/catch error handling

show "Test 1 - Division by zero:"
try:
    show 10 / 0
catch:
    show "Caught division by zero!"

show ""
show "Test 2 - Unknown variable:"
try:
    show unknown_variable
catch error:
    show "Error caught: " + error

show ""
show "Test 3 - Successful try:"
try:
    result = 10 / 2
    show "Result: " + to_text(result)
catch:
    show "This should not print"

show ""
show "All tests complete!"