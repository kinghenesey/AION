# Test AI Memory

use ai

show "=== AI Memory Test ==="
show ""

# Give AI some facts to remember
ai_remember("My name is Emmanuel")
ai_remember("I am building AION programming language")
ai_remember("I am from Nigeria")
ai_remember("I love coding and AI")

show "Facts stored in AI memory."
show ""

# Now ask questions that need memory
show "Question 1:"
answer1 = ai_ask("What is my name and where am I from?")
show answer1

show ""
show "Question 2:"
answer2 = ai_ask("What project am I working on?")
show answer2

show ""
show "Question 3:"
answer3 = ai_ask("Give me advice based on what you know about me")
show answer3

show ""
show "=== Memory Test Complete ==="