# AION AI Ecosystem Demo
# Shows agents and workflows in action

use agents

show "=== AION AI Ecosystem Demo ==="
show ""

# ── Agent Demo ────────────────────────────────────────────────
show "--- Agent System ---"

# Create a research agent
agent_create("researcher", "Research topics and provide summaries")

# Add tools to the agent
agent_tool("researcher", "search", "Search for information")
agent_tool("researcher", "summarize", "Summarize content")

# Run the agent
show ""
show "Running research agent..."
result = agent_run("researcher", "What is artificial intelligence?")
show "Result: " + result

# Check agent memory
show ""
show "Agent memory:"
memory = agent_memory("researcher")
show memory

# Check agent status
status = agent_status("researcher")
show "Agent status: " + status

# ── Workflow Demo ─────────────────────────────────────────────
show ""
show "--- Workflow System ---"

# Create a workflow
workflow_create("content_pipeline", "Generate and save content")

# Add steps
workflow_step("content_pipeline", "generate", "generate", "Write a short tip about programming")
workflow_step("content_pipeline", "summarize", "summarize", "Make it concise")

# Run workflow
show ""
show "Running workflow..."
output = workflow_run("content_pipeline")
show "Workflow output: " + output

# ── Quick AI Tasks ────────────────────────────────────────────
show ""
show "--- Quick AI Tasks ---"

research = ai_research("Python programming language")
show "Research: " + research

plan = ai_plan("Learn AION programming language in 30 days")
show ""
show "Plan: " + plan

# List all agents
show ""
show "--- All Agents ---"
show agent_list()

show ""
show "=== AI Ecosystem Demo Complete ==="