{
    "name": "AION",
    "scopeName": "source.aion",
    "fileTypes": ["aion"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#builtins" },
        { "include": "#modules" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#variables" },
        { "include": "#interpolation" }
    ],
    "repository": {
        "comments": {
            "name": "comment.line.hash.aion",
            "match": "#.*$"
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.aion",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        { "include": "#interpolation" },
                        {
                            "name": "constant.character.escape.aion",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.aion",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.aion",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "interpolation": {
            "name": "meta.interpolation.aion",
            "match": "\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}",
            "captures": {
                "1": {
                    "name": "variable.other.aion"
                }
            }
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.aion",
                    "match": "\\b(if|else|repeat|while|for|in|return|try|catch)\\b"
                },
                {
                    "name": "keyword.declaration.aion",
                    "match": "\\b(task|use|import)\\b"
                },
                {
                    "name": "keyword.operator.logical.aion",
                    "match": "\\b(and|or|not)\\b"
                },
                {
                    "name": "support.function.aion",
                    "match": "\\b(show)\\b"
                }
            ]
        },
        "builtins": {
            "name": "support.function.builtin.aion",
            "match": "\\b(to_text|to_number|length|ask|clear|sleep|type_of|random_num|sqrt|floor|ceil|abs|round|upper|lower|trim|replace|contains|split|join|today|now|year|month|day|ai_ask|ai_summarize|ai_generate|ai_classify|ai_stream|ai_remember|ai_forget|ai_image|db_connect|db_create|db_insert|db_find|db_update|db_delete|db_count|db_close|web_app|web_route|web_start|ui_app|ui_page|ui_title|ui_text|ui_button|ui_save|agent_create|agent_run|agent_tool|workflow_create|workflow_run)\\b"
        },
        "modules": {
            "name": "entity.name.namespace.aion",
            "match": "(?<=use )\\b(math|text|files|datetime|collections|ai|agents|ui|web|database)\\b"
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.aion",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.aion",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "booleans": {
            "name": "constant.language.aion",
            "match": "\\b(true|false|null)\\b"
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.aion",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.aion",
                    "match": "(?<![=!<>])=(?!=)"
                },
                {
                    "name": "keyword.operator.arithmetic.aion",
                    "match": "(\\+|-|\\*\\*|\\*|/|%)"
                }
            ]
        },
        "functions": {
            "name": "entity.name.function.aion",
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        "variables": {
            "name": "variable.other.aion",
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
    }
}