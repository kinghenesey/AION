{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" }
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(if|else|repeat|while|for|task|try|catch)\\b.*:\\s*$",
        "decreaseIndentPattern": "^\\s*(else|catch)\\b"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*(if|else|repeat|while|for|task|try|catch)\\b.*:\\s*$",
            "action": {
                "indent": "indent"
            }
        }
    ],
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}